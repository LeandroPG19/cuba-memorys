# PostgreSQL (optional — auto-provision via Docker if unset)
# DATABASE_URL=postgresql://cuba:memorys2026@localhost:5488/brain

# Core
# RUST_LOG=cuba_memorys=info

# Optional ONNX / runtime
# ONNX_MODEL_PATH=
# ORT_DYLIB_PATH=
# CUBA_RERANKER_PATH=

# v0.8+ features
# CUBA_PROJECT_FILTER=off
# CUBA_SYNC_DIR=./.cuba-memorys
# CUBA_JUDGE=auto
# CUBA_JUEZ_CLI=claude
# CUBA_JUEZ_MODEL=claude-haiku-4-5
# CUBA_JUEZ_TIMEOUT_SECS=30
# CUBA_JUEZ_MAX_PAIRS=5
# ANTHROPIC_API_KEY=

# v0.10 bitemporal (default on; set 0 to disable brain_facts mirror on write)
# CUBA_BITEMPORAL=0

# Backups (scripts/backup-db.sh — keeps last 7 dumps in ./backups/)
# DATABASE_URL=postgresql://cuba:memorys2026@localhost:5488/brain
# BACKUP_DIR=./backups
# KEEP_COUNT=7